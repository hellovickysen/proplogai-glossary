---
import BaseLayout from '../layouts/BaseLayout.astro';
import { glossaryTerms } from '../data/glossary-terms.js';

const categories = [...new Set(glossaryTerms.map(t => t.category))];
const termCount = glossaryTerms.length;

// Group terms alphabetically
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const termsByLetter = {};
alphabet.forEach(letter => {
  const terms = glossaryTerms.filter(t => t.title.toUpperCase().startsWith(letter));
  if (terms.length > 0) {
    termsByLetter[letter] = terms.sort((a, b) => a.title.localeCompare(b.title));
  }
});
const activeLetters = Object.keys(termsByLetter);

// Category colors
const categoryColors = {
  'Trading Psychology': { bg: 'bg-violet-500/10', text: 'text-violet-300', border: 'border-violet-500/20', dot: 'bg-violet-400' },
  'Risk Management': { bg: 'bg-red-500/10', text: 'text-red-300', border: 'border-red-500/20', dot: 'bg-red-400' },
  'Performance Metrics': { bg: 'bg-cyan-500/10', text: 'text-cyan-300', border: 'border-cyan-500/20', dot: 'bg-cyan-400' },
  'Trading Discipline': { bg: 'bg-amber-500/10', text: 'text-amber-300', border: 'border-amber-500/20', dot: 'bg-amber-400' },
  'Prop Firm': { bg: 'bg-emerald-500/10', text: 'text-emerald-300', border: 'border-emerald-500/20', dot: 'bg-emerald-400' },
  'Journal & Analysis': { bg: 'bg-blue-500/10', text: 'text-blue-300', border: 'border-blue-500/20', dot: 'bg-blue-400' },
};

// Sort all terms alphabetically for the main list
const allTermsSorted = [...glossaryTerms].sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout title="Trading Glossary" description={`${termCount} essential trading terms explained for prop firm traders. From FOMO to funded accounts — learn the vocabulary that makes you a better trader.`}>

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-[0.07]" style="background: radial-gradient(ellipse, #8b5cf6, transparent 70%);"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-6 pt-12 pb-10 sm:px-10 sm:pt-16 sm:pb-14 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-white/[0.08] bg-white/[0.03] px-4 py-1.5 mb-6 animate-fade-in-up">
        <span class="font-mono text-[11px] tracking-wider text-white/40 uppercase">Trading Glossary</span>
        <span class="h-1 w-1 rounded-full bg-violet-400/60"></span>
        <span class="font-mono text-[11px] tracking-wider text-violet-400/80" id="term-counter">{termCount} terms</span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] animate-fade-in-up stagger-1">
        Every term a trader<br />
        <span class="gradient-text">needs to know.</span>
      </h1>

      <p class="mt-5 mx-auto max-w-xl text-base sm:text-lg text-white/50 leading-relaxed animate-fade-in-up stagger-2">
        From trading psychology to prop firm rules — plain-language definitions with real examples, not textbook jargon.
      </p>

      <!-- Search Bar -->
      <div class="mt-8 mx-auto max-w-lg animate-fade-in-up stagger-3">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/25 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input
            type="text"
            id="glossary-search"
            placeholder="Search terms... e.g. drawdown, FOMO, win rate"
            class="w-full rounded-2xl border border-white/[0.08] bg-white/[0.03] pl-12 pr-4 py-3.5 text-sm text-white outline-none placeholder:text-white/25 focus:border-violet-400/40 focus:bg-white/[0.05] transition-all"
          />
          <span id="search-count" class="absolute right-4 top-1/2 -translate-y-1/2 font-mono text-[11px] text-white/25 hidden"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Filter Pills -->
  <section class="mx-auto max-w-5xl px-6 sm:px-10 pb-4">
    <div class="flex flex-wrap items-center gap-2 justify-center" id="category-filters">
      <button class="category-pill active rounded-full px-4 py-2 text-sm font-medium text-white/70" data-category="all">
        All
      </button>
      {categories.map(cat => {
        const colors = categoryColors[cat] || { bg: 'bg-white/5', text: 'text-white/60', border: 'border-white/10', dot: 'bg-white/40' };
        return (
          <button class="category-pill rounded-full px-4 py-2 text-sm font-medium text-white/50 flex items-center gap-2" data-category={cat}>
            <span class={`w-2 h-2 rounded-full ${colors.dot}`}></span>
            {cat}
          </button>
        );
      })}
    </div>
  </section>

  <!-- Alphabet Jump Bar -->
  <section class="mx-auto max-w-5xl px-6 sm:px-10 py-4">
    <div class="flex flex-wrap justify-center gap-1" id="alpha-bar">
      {alphabet.map(letter => (
        <a
          href={`#letter-${letter}`}
          class={`alpha-btn ${activeLetters.includes(letter) ? 'has-terms' : 'opacity-30 pointer-events-none'}`}
          data-letter={letter}
        >
          {letter}
        </a>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-5xl px-6 sm:px-10">
    <div class="gradient-divider"></div>
  </div>

  <!-- Terms Grid -->
  <section class="mx-auto max-w-5xl px-6 sm:px-10 py-10" id="terms-container">
    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-16">
      <div class="text-4xl mb-4">🔍</div>
      <p class="text-lg text-white/50 font-medium">No terms found</p>
      <p class="text-sm text-white/30 mt-1">Try a different search term or category</p>
    </div>

    {activeLetters.sort().map(letter => (
      <div class="letter-section mb-10" id={`letter-${letter}`} data-letter={letter}>
        <!-- Letter header -->
        <div class="flex items-center gap-4 mb-5">
          <span class="font-display text-3xl font-bold gradient-text">{letter}</span>
          <div class="flex-1 h-px bg-white/[0.06]"></div>
          <span class="font-mono text-[10px] text-white/20 uppercase tracking-wider">{termsByLetter[letter].length} {termsByLetter[letter].length === 1 ? 'term' : 'terms'}</span>
        </div>

        <!-- Terms in this letter -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {termsByLetter[letter].map(term => {
            const colors = categoryColors[term.category] || { bg: 'bg-white/5', text: 'text-white/60', border: 'border-white/10' };
            return (
              <a
                href={`/glossary/${term.slug}`}
                class="term-card p-5 group block"
                data-slug={term.slug}
                data-category={term.category}
                data-title={term.title.toLowerCase()}
                data-def={term.shortDefinition.toLowerCase()}
              >
                <!-- Card Header -->
                <div class="flex items-start justify-between gap-3">
                  <div class="flex-1 min-w-0">
                    <h3 class="font-display text-base font-semibold text-white group-hover:text-violet-200 transition-colors leading-snug">
                      {term.title}
                    </h3>
                    <span class={`inline-flex items-center gap-1 mt-2 rounded-full ${colors.bg} ${colors.text} border ${colors.border} px-2 py-[2px] text-[9px] font-medium uppercase tracking-wide`}>
                      {term.category}
                    </span>
                  </div>
                  <!-- Arrow icon -->
                  <span class="mt-1 grid h-7 w-7 flex-shrink-0 place-items-center rounded-lg bg-white/[0.04] text-white/20 transition-all group-hover:bg-white/[0.08] group-hover:text-white/50">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
                    </svg>
                  </span>
                </div>

                <!-- Short definition -->
                <p class="mt-3 text-sm text-white/45 leading-relaxed line-clamp-2">
                  {term.shortDefinition}
                </p>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </section>

  <!-- CTA Section -->
  <section class="mx-auto max-w-5xl px-6 sm:px-10 pb-16">
    <div class="relative rounded-2xl border border-white/[0.08] bg-white/[0.02] p-8 sm:p-12 text-center overflow-hidden">
      <div class="absolute inset-0 opacity-[0.04]" style="background: radial-gradient(ellipse at center, #8b5cf6, transparent 70%);"></div>
      <div class="relative">
        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight text-white">
          Don't just learn the terms.<br />
          <span class="gradient-text">Track them in your journal.</span>
        </h2>
        <p class="mt-4 mx-auto max-w-md text-sm text-white/40 leading-relaxed">
          PropLogAI tracks your psychology, discipline, and performance automatically. Every term in this glossary becomes a measurable part of your trading improvement.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="https://proplogai.com/login?mode=signup"
            class="rounded-full px-6 py-3 text-sm font-semibold text-[#08080f]"
            style="background:linear-gradient(120deg,#a78bfa,#22d3ee);"
          >
            Start Free Trial
          </a>
          <a
            href="https://proplogai.com/pricing"
            class="rounded-full border border-white/10 bg-white/[0.04] px-6 py-3 text-sm font-medium text-white/60 hover:text-white hover:border-white/20 transition-colors"
          >
            View Pricing
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Search ──
  const searchInput = document.getElementById('glossary-search');
  const searchCount = document.getElementById('search-count');
  const noResults = document.getElementById('no-results');
  const termCards = document.querySelectorAll('.term-card');
  const letterSections = document.querySelectorAll('.letter-section');

  let activeCategory = 'all';

  function filterTerms() {
    const query = searchInput?.value?.toLowerCase().trim() || '';
    let visibleCount = 0;

    termCards.forEach(card => {
      const title = card.dataset.title || '';
      const def = card.dataset.def || '';
      const category = card.dataset.category || '';

      const matchesSearch = !query || title.includes(query) || def.includes(query);
      const matchesCategory = activeCategory === 'all' || category === activeCategory;
      const visible = matchesSearch && matchesCategory;

      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Show/hide letter sections based on visible children
    letterSections.forEach(section => {
      const visibleCards = section.querySelectorAll('.term-card:not([style*="display: none"])');
      section.style.display = visibleCards.length > 0 ? '' : 'none';
    });

    // Search count badge
    if (searchCount) {
      if (query || activeCategory !== 'all') {
        searchCount.textContent = `${visibleCount} found`;
        searchCount.classList.remove('hidden');
      } else {
        searchCount.classList.add('hidden');
      }
    }

    // No results
    if (noResults) {
      noResults.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  searchInput?.addEventListener('input', filterTerms);

  // ── Category Filters ──
  const filterBtns = document.querySelectorAll('#category-filters .category-pill');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.category || 'all';
      filterTerms();
    });
  });

  // ── Alphabet Smooth Scroll ──
  document.querySelectorAll('#alpha-bar a').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
